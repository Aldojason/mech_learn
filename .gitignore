# Python virtual environment
venv/*
!venv/share/jupyter/kernels/python3/train.ipynb

# Exclude directories that should stay local
/scripts/
/lib/
/include/

!venv/share/jupyter/kernels/python3/kernel.json
!venv/share/jupyter/kernels/python3/logo-svg.svg
# Local notebook artifacts
!venv/share/jupyter/kernels/python3/laptops.csv
!venv/share/jupyter/kernels/python3/laptop.ipynb
!venv/share/jupyter/kernels/python3/data.csv
!venv/share/jupyter/kernels/python3/data.ipynb
!venv/share/jupyter/kernels/python3/CAR DETAILS FROM CAR DEKHO.csv

# Python cache and local artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Images and notebooks output
*.png
*.jpg
*.jpeg
*.gif
*.webp
.ipynb_checkpoints/
